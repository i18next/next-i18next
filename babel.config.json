{
  "env": {
    "test": {
      "presets": [
        "@babel/preset-typescript",
        [
          "@babel/env",
          {
            "targets": {
              "node": "current"
            },
            "modules": "commonjs"
          }
        ],
        ["@babel/preset-react"]
      ],
      "plugins": [
        [
          "add-module-exports",
          {
            "addDefaultProperty": true
          }
        ]
      ]
    }
  }
}
